---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

const posts = (
	await getCollection("posts", ({ data }) =>
		import.meta.env.DEV ? true : !data.draft,
	)
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date) {
	return date.toLocaleDateString("en-US", {
		year: "numeric",
		month: "long",
		day: "numeric",
	});
}
---

<Layout>
	<main class="page">
		<header class="header">
			<h1>Reyansh Bahl</h1>
			<p class="tagline">Writing on software and other things.</p>

			<div class="actions">
				<a
					href="https://x.com/reyanshbahl"
					target="_blank"
					rel="noopener noreferrer"
					class="button"
					aria-label="Follow @reyanshbahl on X"
				>
					<svg
						width="14"
						height="14"
						viewBox="0 0 24 24"
						fill="currentColor"
						aria-hidden="true"
					>
						<path
							d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
						></path>
					</svg>
					@reyanshbahl
				</a>
				<a
					href="https://github.com/reybahl"
					target="_blank"
					rel="noopener noreferrer"
					class="button"
					aria-label="View @reybahl on GitHub"
				>
					<svg
						width="14"
						height="14"
						viewBox="0 0 24 24"
						fill="currentColor"
						aria-hidden="true"
					>
						<path
							d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
						></path>
					</svg>
					@reybahl
				</a>
			</div>
		</header>

		<section class="posts" aria-label="Posts">
			{
				posts.length === 0 ? (
					<p class="empty">No posts yet.</p>
				) : (
					<ul class="post-list">
						{posts.map((post) => (
							<li>
								<a href={`/posts/${post.id}`} class="post-card">
									<time
										class="post-date"
										datetime={post.data.date.toISOString()}
									>
										{formatDate(post.data.date)}
									</time>
									<h2 class="post-title">{post.data.title}</h2>
									<p class="post-description">{post.data.description}</p>
								</a>
							</li>
						))}
					</ul>
				)
			}
		</section>

		<section class="archive" aria-label="Archive">
			<p class="archive-note">
				View my old Medium posts (from 2021–2023)
				<a
					href="https://reybahl.medium.com"
					target="_blank"
					rel="noopener noreferrer"
				>
					here!
				</a>
			</p>
		</section>
	</main>
</Layout>

<style>
	.page {
		max-width: 32rem;
		margin: 0 auto;
		padding: 4rem 1.5rem 3rem;
		min-height: 100dvh;
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.5rem;
		margin-top: 1.25rem;
	}

	.button {
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		padding: 0.375rem 0.875rem;
		border: 1px solid var(--border);
		border-radius: 0.375rem;
		background: var(--button-bg);
		color: var(--button-text);
		font-size: 0.875rem;
		line-height: 1;
		text-decoration: none;
	}

	.button:hover {
		background: var(--button-hover);
	}

	.button svg {
		display: block;
		width: 0.875rem;
		height: 0.875rem;
		flex-shrink: 0;
	}

	.header {
		margin-bottom: 3rem;
	}

	h1 {
		margin: 0;
		font-size: 1.5rem;
		font-weight: 600;
		letter-spacing: -0.02em;
	}

	.tagline {
		margin: 0.5rem 0 0;
		color: var(--muted);
		font-size: 0.9375rem;
	}

	.empty {
		margin: 0;
		color: var(--muted);
		font-size: 0.9375rem;
	}

	.post-list {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.post-card {
		display: block;
		padding: 1rem 1.125rem;
		border: 1px solid var(--border);
		border-radius: 0.375rem;
		text-decoration: none;
		transition: border-color 0.15s ease;
	}

	.post-card:hover {
		border-color: var(--text);
	}

	.post-date {
		display: block;
		color: var(--muted);
		font-size: 0.8125rem;
	}

	.post-title {
		margin: 0.375rem 0 0;
		font-size: 1rem;
		font-weight: 600;
		letter-spacing: -0.01em;
		line-height: 1.3;
	}

	.post-description {
		margin: 0.375rem 0 0;
		color: var(--muted);
		font-size: 0.875rem;
		line-height: 1.5;
	}

	.archive {
		margin-top: 2.5rem;
		padding-top: 2.5rem;
		border-top: 1px solid var(--border);
	}

	.archive-note {
		margin: 0;
		color: var(--muted);
		font-size: 0.9375rem;
	}

	.archive-note a {
		color: var(--text);
		text-decoration: underline;
		text-underline-offset: 0.15em;
	}

	.archive-note a:hover {
		text-decoration: none;
	}
</style>

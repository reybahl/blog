---
import { getCollection } from "astro:content";
import BrandIcon from "../components/BrandIcon.astro";
import Layout from "../layouts/Layout.astro";

const posts = (
	await getCollection("posts", ({ data }) =>
		import.meta.env.DEV ? true : !data.draft,
	)
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date) {
	return date.toLocaleDateString("en-US", {
		year: "numeric",
		month: "long",
		day: "numeric",
	});
}
---

<Layout>
	<main class="page">
		<header class="header">
			<h1>Reyansh Bahl</h1>
			<p class="tagline">Writing on software and other things.</p>

			<div class="actions">
				<a
					href="https://x.com/reyanshbahl"
					target="_blank"
					rel="noopener noreferrer"
					class="button"
					aria-label="Follow @reyanshbahl on X"
				>
					<BrandIcon name="X" />
					@reyanshbahl
				</a>
				<a
					href="https://github.com/reybahl"
					target="_blank"
					rel="noopener noreferrer"
					class="button"
					aria-label="View @reybahl on GitHub"
				>
					<BrandIcon name="GitHub" />
					@reybahl
				</a>
			</div>
		</header>

		<section class="posts" aria-label="Posts">
			{
				posts.length === 0 ? (
					<p class="empty">No posts yet.</p>
				) : (
					<ul class="post-list">
						{posts.map((post) => (
							<li>
								<a href={`/posts/${post.id}`} class="post-card">
									<time
										class="post-date"
										datetime={post.data.date.toISOString()}
									>
										{formatDate(post.data.date)}
									</time>
									<h2 class="post-title">{post.data.title}</h2>
									<p class="post-description">{post.data.description}</p>
								</a>
							</li>
						))}
					</ul>
				)
			}
		</section>

		<section class="archive" aria-label="Archive">
			<p class="archive-note">
				View my old Medium posts (from 2021–2023)
				<a
					href="https://reybahl.medium.com"
					target="_blank"
					rel="noopener noreferrer"
				>
					here!
				</a>
			</p>
		</section>
	</main>
</Layout>

<style>
	.page {
		max-width: 32rem;
		margin: 0 auto;
		padding: 4rem 1.5rem 3rem;
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.5rem;
		margin-top: 1.25rem;
	}

	.button {
		display: inline-flex;
		align-items: center;
		gap: 0.375rem;
		padding: 0.375rem 0.875rem;
		border: 1px solid var(--border);
		border-radius: 0.375rem;
		background: transparent;
		color: var(--text);
		font-size: 0.875rem;
		line-height: 1;
		text-decoration: none;
		transition: border-color 0.15s ease;
	}

	.button:hover {
		border-color: var(--text);
	}

	.button :global(svg) {
		display: block;
		width: 0.875rem;
		height: 0.875rem;
		flex-shrink: 0;
	}

	.header {
		margin-bottom: 3rem;
	}

	h1 {
		margin: 0;
		font-size: 1.5rem;
		font-weight: 600;
		letter-spacing: -0.02em;
	}

	.tagline {
		margin: 0.5rem 0 0;
		color: var(--muted);
		font-size: 0.9375rem;
	}

	.empty {
		margin: 0;
		color: var(--muted);
		font-size: 0.9375rem;
	}

	.post-list {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.post-card {
		display: block;
		padding: 1rem 1.125rem;
		border: 1px solid var(--border);
		border-radius: 0.375rem;
		text-decoration: none;
		transition: border-color 0.15s ease;
	}

	.post-card:hover {
		border-color: var(--text);
	}

	.post-date {
		display: block;
		color: var(--muted);
		font-size: 0.8125rem;
	}

	.post-title {
		margin: 0.375rem 0 0;
		font-size: 1rem;
		font-weight: 600;
		letter-spacing: -0.01em;
		line-height: 1.3;
	}

	.post-description {
		margin: 0.375rem 0 0;
		color: var(--muted);
		font-size: 0.875rem;
		line-height: 1.5;
	}

	.archive {
		margin-top: 2.5rem;
		padding-top: 2.5rem;
		border-top: 1px solid var(--border);
	}

	.archive-note {
		margin: 0;
		color: var(--muted);
		font-size: 0.9375rem;
	}

	.archive-note a {
		color: var(--text);
		text-decoration: underline;
		text-underline-offset: 0.15em;
	}

	.archive-note a:hover {
		text-decoration: none;
	}
</style>

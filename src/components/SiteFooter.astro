---
import BrandIcon from "./BrandIcon.astro";
---

<footer class="footer">
	<a href="/" class="name">Overline</a>
	<div class="links">
		<a
			href="https://github.com/reybahl/patch"
			target="_blank"
			rel="noopener noreferrer"
			aria-label="GitHub (reybahl/patch)"
		>
			<BrandIcon name="GitHub" />
		</a>
	</div>
</footer>

<style>
	.footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		width: 100%;
		max-width: 32rem;
		margin: 0 auto;
		padding: 2rem 1.5rem 3rem;
		border-top: 1px solid var(--border);
	}

	.name {
		margin: 0;
		font-size: 0.875rem;
		font-weight: 600;
		letter-spacing: -0.01em;
		text-decoration: none;
	}

	.name:hover {
		text-decoration: underline;
		text-underline-offset: 0.15em;
	}

	.links {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.links a {
		display: flex;
		color: var(--muted);
		text-decoration: none;
		transition: color 0.15s ease;
	}

	.links a:hover {
		color: var(--text);
	}

	.links :global(svg) {
		display: block;
	}
</style>

---
import Layout from "./Layout.astro";

interface Props {
	title: string;
	description: string;
	date: Date;
}

const { title, description, date } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
	year: "numeric",
	month: "long",
	day: "numeric",
});
---

<Layout title={`${title} | Reyansh Bahl`} description={description}>
	<main class="page">
		<article class="article">
			<header class="header">
				<a href="/" class="back">← Home</a>
				<time class="date" datetime={date.toISOString()}>{formattedDate}</time>
				<h1>{title}</h1>
				<p class="description">{description}</p>
			</header>
			<div class="content">
				<slot />
			</div>
		</article>
	</main>
</Layout>

<style>
	.page {
		max-width: 32rem;
		margin: 0 auto;
		padding: 4rem 1.5rem 3rem;
	}

	.back {
		display: inline-block;
		margin-bottom: 2rem;
		color: var(--muted);
		font-size: 0.875rem;
		text-decoration: none;
	}

	.back:hover {
		color: var(--text);
	}

	.date {
		display: block;
		color: var(--muted);
		font-size: 0.875rem;
	}

	h1 {
		margin: 0.375rem 0 0;
		font-size: 1.5rem;
		font-weight: 600;
		letter-spacing: -0.02em;
		line-height: 1.25;
	}

	.description {
		margin: 0.75rem 0 0;
		color: var(--muted);
		font-size: 0.9375rem;
		line-height: 1.5;
	}

	.content {
		margin-top: 2.5rem;
		padding-top: 2.5rem;
		border-top: 1px solid var(--border);
		font-size: 0.9375rem;
		line-height: 1.65;
	}

	.content :global(h2) {
		margin: 2rem 0 0.75rem;
		font-size: 1.125rem;
		font-weight: 600;
		letter-spacing: -0.01em;
	}

	.content :global(h3) {
		margin: 1.5rem 0 0.5rem;
		font-size: 1rem;
		font-weight: 600;
	}

	.content :global(p) {
		margin: 0.75rem 0 0;
	}

	.content :global(a) {
		text-decoration: underline;
		text-underline-offset: 0.15em;
	}

	.content :global(a:hover) {
		text-decoration: none;
	}

	.content :global(img) {
		display: block;
		max-width: 100%;
		height: auto;
		margin: 1.25rem auto 0;
	}
</style>
